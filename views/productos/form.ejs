<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0"><%= title %></h4>
            </div>
            <div class="card-body">
                <% if (error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>
                <form action="<%= accion %>" method="<%= metodo %>" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="nombre" class="form-label">Nombre del producto <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="nombre" name="nombre"
                               value="<%= producto.nombre || '' %>" required maxlength="150">
                    </div>

                    <div class="mb-3">
                        <label for="id_almacen" class="form-label">Almacen <span class="text-danger">*</span></label>
                        <select class="form-select" id="id_almacen" name="id_almacen" required>
                            <option value="">-- Selecciona un almacen --</option>
                            <% almacenes.forEach(function(a) { %>
                                <option value="<%= a.id_almacen %>"
                                    <%= String(producto.id_almacen) === String(a.id_almacen) ? 'selected' : '' %>>
                                    <%= a.nombre %>
                                </option>
                            <% }); %>
                        </select>
                        <% if (almacenes.length === 0) { %>
                            <small class="text-danger">
                                No hay almacenes registrados. <a href="/almacenes/nuevo">Crea uno primero</a>.
                            </small>
                        <% } %>
                    </div>

                    <div class="mb-3">
                        <label for="imagen" class="form-label">Imagen del producto</label>
                        <input type="file" class="form-control" id="imagen" name="imagen" accept="image/*">
                        <small class="text-muted">Formatos: jpg, png, gif, webp. Maximo 5 MB.</small>
                    </div>

                    <% if (producto.imagen) { %>
                        <div class="mb-3">
                            <label class="form-label d-block">Imagen actual:</label>
                            <img src="<%= producto.imagen %>" alt="Imagen actual"
                                 class="img-thumbnail" style="max-width: 200px;">
                            <small class="d-block text-muted mt-1">
                                Si subes una nueva imagen, esta sera reemplazada.
                            </small>
                        </div>
                    <% } %>

                    <div class="d-flex justify-content-between">
                        <a href="/productos" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-save"></i> Guardar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
