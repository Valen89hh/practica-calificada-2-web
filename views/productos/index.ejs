<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-bag"></i> Productos</h2>
    <a href="/productos/nuevo" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Nuevo Producto
    </a>
</div>

<% if (mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= mensaje %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
<% } %>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th style="width: 120px;">Imagen</th>
                    <th>Nombre</th>
                    <th>Almacen</th>
                    <th style="width: 200px;" class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% if (productos.length === 0) { %>
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            No hay productos registrados.
                        </td>
                    </tr>
                <% } %>
                <% productos.forEach(function(p) { %>
                    <tr>
                        <td><%= p.id_producto %></td>
                        <td>
                            <% if (p.imagen) { %>
                                <img src="<%= p.imagen %>" alt="<%= p.nombre %>"
                                     class="img-thumbnail" style="width: 80px; height: 80px; object-fit: cover;">
                            <% } else { %>
                                <div class="bg-secondary-subtle d-flex align-items-center justify-content-center rounded"
                                     style="width: 80px; height: 80px;">
                                    <i class="bi bi-image text-muted"></i>
                                </div>
                            <% } %>
                        </td>
                        <td><%= p.nombre %></td>
                        <td>
                            <span class="badge bg-info text-dark">
                                <i class="bi bi-building"></i> <%= p.almacen_nombre %>
                            </span>
                        </td>
                        <td class="text-end">
                            <a href="/productos/<%= p.id_producto %>/editar" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                            <form action="/productos/<%= p.id_producto %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('¿Eliminar este producto?');">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
