<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-building"></i> Almacenes</h2>
    <a href="/almacenes/nuevo" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nuevo Almacen
    </a>
</div>

<% if (mensaje) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= mensaje %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
<% } %>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>Nombre</th>
                    <th style="width: 200px;" class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% if (almacenes.length === 0) { %>
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">
                            No hay almacenes registrados.
                        </td>
                    </tr>
                <% } %>
                <% almacenes.forEach(function(a) { %>
                    <tr>
                        <td><%= a.id_almacen %></td>
                        <td><%= a.nombre %></td>
                        <td class="text-end">
                            <a href="/almacenes/<%= a.id_almacen %>/editar" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                            <form action="/almacenes/<%= a.id_almacen %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('¿Eliminar este almacen? Tambien se borraran sus productos.');">
                                <button type="submit" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>
